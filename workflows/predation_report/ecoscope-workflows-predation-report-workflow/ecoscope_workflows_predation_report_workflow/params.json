{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set workflow details"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "title": "Time Format",
          "type": "string",
          "description": "The time format",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Define analysis time range"
    },
    "time_frequency": {
      "additionalProperties": false,
      "properties": {
        "time_frequency": {
          "$ref": "#/$defs/TimeFrequency",
          "title": "Time Frequency",
          "description": "The time frequency to use across all time-series charts in the workflow."
        }
      },
      "required": [
        "time_frequency"
      ],
      "type": "object",
      "title": "Select time frequency for temporal charts"
    },
    "load_local_lg_file": {
      "additionalProperties": false,
      "properties": {
        "file_path": {
          "format": "file-path",
          "title": "File Path",
          "type": "string",
          "description": "Path to the tabular file (CSV or Parquet)."
        }
      },
      "required": [
        "file_path"
      ],
      "type": "object",
      "title": "Load local tabular file"
    }
  },
  "$defs": {
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "TimeFrequency": {
      "enum": [
        "Year",
        "Quarter",
        "Month",
        "Week",
        "Day",
        "Hour",
        "Minute"
      ],
      "title": "TimeFrequency",
      "type": "string"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone",
        "time_format"
      ]
    },
    "ui:order": [
      "workflow_details",
      "time_range",
      "time_frequency",
      "load_local_lg_file"
    ]
  },
  "additionalProperties": false
}
