{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set workflow details"
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to EarthRanger"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "title": "Time Format",
          "type": "string",
          "description": "The time format",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Define analysis time range"
    },
    "subject_group_var": {
      "additionalProperties": false,
      "properties": {
        "var": {
          "title": "",
          "type": "string"
        }
      },
      "required": [
        "var"
      ],
      "type": "object",
      "title": "Set subject group name"
    },
    "convert_to_trajs": {
      "additionalProperties": false,
      "properties": {
        "trajectory_segment_filter": {
          "allOf": [
            {
              "$ref": "#/$defs/TrajectorySegmentFilter"
            }
          ],
          "default": {
            "min_length_meters": 0.001,
            "max_length_meters": 100000,
            "min_time_secs": 1,
            "max_time_secs": 172800,
            "min_speed_kmhr": 0.01,
            "max_speed_kmhr": 500
          },
          "title": " ",
          "description": "Filter track data by setting limits on track segment length, duration, and speed. Segments outside these bounds are removed, reducing noise and to focus on meaningful movement patterns.",
          "ecoscope:advanced": true
        }
      },
      "required": [],
      "type": "object",
      "title": "Convert relocations to trajectories"
    },
    "terrain_exaggeration": {
      "additionalProperties": false,
      "properties": {
        "exaggeration": {
          "default": 1.0,
          "exclusiveMinimum": 0.0,
          "title": "Exaggeration",
          "type": "number",
          "description": "Vertical exaggeration factor. 1.0 = true scale, 2.0 = 2x heights.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Configure terrain elevation decoder"
    },
    "trips_view_state": {
      "additionalProperties": false,
      "properties": {
        "pitch": {
          "default": 45,
          "maximum": 90,
          "minimum": 0,
          "title": "Pitch",
          "type": "integer",
          "description": "Camera tilt in degrees (0 = top-down, 90 = horizon). 45\u00b0 gives a natural 3-D perspective over terrain.",
          "ecoscope:advanced": true
        },
        "bearing": {
          "default": 0,
          "maximum": 180,
          "minimum": -180,
          "title": "Bearing",
          "type": "integer",
          "description": "Camera compass heading in degrees (0 = north, 90 = east, -90 = west). Rotates the map so a different cardinal direction faces up.",
          "ecoscope:advanced": true
        }
      },
      "required": [],
      "type": "object",
      "title": "Calculate map view bounds"
    },
    "animation_settings": {
      "additionalProperties": false,
      "properties": {
        "animation_speed": {
          "default": 1000,
          "minimum": 0.0,
          "title": "Animation Speed",
          "type": "number",
          "ecoscope:advanced": true
        },
        "auto_rotate_speed": {
          "default": 0.0,
          "title": "Auto Rotate Speed",
          "type": "number",
          "description": "Camera rotation speed in degrees per second. 0 = off; positive = clockwise; negative = counter-clockwise.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Configure animation settings"
    },
    "draw_animation": {
      "additionalProperties": false,
      "properties": {
        "head_layer": {
          "allOf": [
            {
              "$ref": "#/$defs/ScenegraphLayerDefinition"
            }
          ],
          "default": {
            "enabled": false,
            "glb": "https://raw.githubusercontent.com/wildlife-dynamics/animate_subject_tracks/main/african_bush_elephant.glb",
            "size_scale": 50.0,
            "size_min_pixels": 12.0,
            "size_max_pixels": 75.0,
            "face_heading": true,
            "yaw_offset": 0.0,
            "model_pitch": 90.0,
            "model_roll": 0.0,
            "smooth_samples": 2,
            "terrain_pitch": false,
            "terrain_pitch_scale": 1.0,
            "min_move_m": 3.0,
            "pbr_lighting": true,
            "tint": [
              220,
              220,
              255
            ],
            "use_track_color": true
          },
          "title": "Head Layer",
          "description": "3D glTF/GLB head model settings. Enable with the 'enabled' checkbox.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Draw animated map"
    },
    "video_output_path": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "type": "object",
      "required": [],
      "title": "Configure video export"
    },
    "create_animation": {
      "additionalProperties": false,
      "properties": {
        "camera": {
          "default": "static",
          "enum": [
            "static",
            "follow",
            "follow_3d",
            "orbit",
            "fit",
            "cinematic"
          ],
          "title": "Camera",
          "type": "string"
        },
        "fps": {
          "default": 30,
          "exclusiveMinimum": 0,
          "title": "Fps",
          "type": "integer"
        },
        "duration": {
          "allOf": [
            {
              "$ref": "#/$defs/DurationConfig"
            }
          ],
          "default": {
            "auto": true,
            "seconds": 75.0
          },
          "title": "Duration"
        },
        "width": {
          "default": 1280,
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "integer"
        },
        "height": {
          "default": 720,
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "integer"
        }
      },
      "required": [],
      "type": "object",
      "title": "Render animation video"
    }
  },
  "$defs": {
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "TrajectorySegmentFilter": {
      "properties": {
        "min_length_meters": {
          "default": 0.001,
          "ecoscope:advanced": true,
          "minimum": 0.001,
          "title": "Minimum Segment Length (Meters)",
          "type": "number"
        },
        "max_length_meters": {
          "default": 100000,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Length (Meters)",
          "type": "number"
        },
        "min_time_secs": {
          "default": 1,
          "ecoscope:advanced": true,
          "minimum": 1,
          "title": "Minimum Segment Duration (Seconds)",
          "type": "number"
        },
        "max_time_secs": {
          "default": 172800,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 1,
          "title": "Maximum Segment Duration (Seconds)",
          "type": "number"
        },
        "min_speed_kmhr": {
          "default": 0.01,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Minimum Segment Speed (Kilometers per Hour)",
          "type": "number"
        },
        "max_speed_kmhr": {
          "default": 500,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Speed (Kilometers per Hour)",
          "type": "number"
        }
      },
      "title": "TrajectorySegmentFilter",
      "type": "object"
    },
    "ScenegraphLayerDefinition": {
      "description": "An animated 3D head built from a glTF/GLB model (deck.gl ScenegraphLayer).\n\nCreate one with create_scenegraph_layer() and pass it to\ndraw_animated_map(head_layer=...). Its position and heading are driven per-frame\nfrom the TripsLayer, so it follows each subject's current location. `glb` accepts\nan http(s) URL, a `data:` URI, or a local file path (read and embedded as a data\nURI). None -> bundled default (the elephant model). If the ScenegraphLayer\nconstructor or the glTF loader can't be resolved at runtime, the head silently\nfalls back to the flat ScatterplotLayer dot.\nSee https://deck.gl/docs/api-reference/mesh-layers/scenegraph-layer for more info.",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable the 3D head model. When off, subjects render as flat dots.",
          "ecoscope:advanced": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "glb": {
          "default": "https://raw.githubusercontent.com/wildlife-dynamics/animate_subject_tracks/main/african_bush_elephant.glb",
          "description": "GLB source: an http(s) URL, a data: URI, or a local file path. None -> bundled default model (elephant).",
          "ecoscope:advanced": true,
          "title": "Glb",
          "type": "string"
        },
        "size_scale": {
          "default": 50.0,
          "description": "ScenegraphLayer sizeScale. Tune to your scene.",
          "ecoscope:advanced": true,
          "title": "Size Scale",
          "type": "number"
        },
        "size_min_pixels": {
          "default": 12.0,
          "description": "Clamp the on-screen model to at least this many pixels so it stays visible when zoomed out.",
          "ecoscope:advanced": true,
          "title": "Size Min Pixels",
          "type": "number"
        },
        "size_max_pixels": {
          "default": 75.0,
          "description": "Optional upper clamp on the model's on-screen size in pixels.",
          "ecoscope:advanced": true,
          "title": "Size Max Pixels",
          "type": "number"
        },
        "face_heading": {
          "default": true,
          "description": "Rotate the model to face its direction of travel.",
          "ecoscope:advanced": true,
          "title": "Face Heading",
          "type": "boolean"
        },
        "yaw_offset": {
          "default": 0.0,
          "description": "Degrees added to the computed heading so the model's nose aligns with travel. Model-dependent; tweak if your model faces sideways.",
          "ecoscope:advanced": true,
          "title": "Yaw Offset",
          "type": "number"
        },
        "model_pitch": {
          "default": 90.0,
          "description": "Tilt of the MODEL itself (deg), independent of the camera. Use to correct a model authored nose-up/down; NOT the view pitch.",
          "ecoscope:advanced": true,
          "title": "Model Pitch",
          "type": "number"
        },
        "model_roll": {
          "default": 0.0,
          "description": "Bank of the MODEL itself (deg), independent of the camera.",
          "ecoscope:advanced": true,
          "title": "Model Roll",
          "type": "number"
        },
        "smooth_samples": {
          "default": 2,
          "description": "Heading/slope smoothing window in track fixes (+/- N). Higher = smoother orientation but more lag; 0 = raw single segment.",
          "ecoscope:advanced": true,
          "title": "Smooth Samples",
          "type": "integer"
        },
        "terrain_pitch": {
          "default": false,
          "description": "Tilt the model to the terrain slope (from each fix's z) so it noses up on climbs / down on descents. OFF by default -> stays upright; enable only for steady, climbing tracks (it can tip near-stationary subjects).",
          "ecoscope:advanced": true,
          "title": "Terrain Pitch",
          "type": "boolean"
        },
        "terrain_pitch_scale": {
          "default": 1.0,
          "description": "Sign/strength of terrain pitch. Set -1.0 to flip if the model tilts the wrong way; <1 to soften. (Tilt is also capped at +/-20deg.)",
          "ecoscope:advanced": true,
          "title": "Terrain Pitch Scale",
          "type": "number"
        },
        "min_move_m": {
          "default": 3.0,
          "description": "If the subject moves less than this (m) across the smoothing window, hold the last heading and keep the model level -- stops it spinning or tipping while milling in place.",
          "ecoscope:advanced": true,
          "title": "Min Move M",
          "type": "number"
        },
        "pbr_lighting": {
          "default": true,
          "description": "Physically-based lighting ('pbr'); False -> flat shading.",
          "ecoscope:advanced": true,
          "title": "Pbr Lighting",
          "type": "boolean"
        },
        "tint": {
          "default": [
            220,
            220,
            255
          ],
          "description": "Optional RGB tint over the model as [R, G, B]. None -> the model's own materials.",
          "ecoscope:advanced": true,
          "items": {
            "type": "integer"
          },
          "title": "Tint",
          "type": "array"
        },
        "use_track_color": {
          "default": true,
          "description": "Colour the model with each subject's track colour. False -> use `tint` (or the model's own materials). Note: the colour multiplies the model's material, so it reads truest with a light/neutral glb and flat lighting (pbr_lighting=False).",
          "ecoscope:advanced": true,
          "title": "Use Track Color",
          "type": "boolean"
        }
      },
      "title": "ScenegraphLayerDefinition",
      "type": "object"
    },
    "DurationConfig": {
      "properties": {
        "auto": {
          "default": true,
          "description": "Match the animation's own playback length. Uncheck to set a fixed duration.",
          "title": "Auto",
          "type": "boolean"
        },
        "seconds": {
          "default": 75.0,
          "description": "Video duration in seconds. Used when auto is off, or as a fallback when auto cannot determine the length.",
          "title": "Seconds",
          "type": "number"
        }
      },
      "title": "DurationConfig",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone",
        "time_format"
      ]
    },
    "trips_view_state": {
      "ui:order": [
        "pitch",
        "bearing"
      ]
    },
    "animation_settings": {
      "ui:order": [
        "animation_speed",
        "auto_rotate_speed"
      ]
    },
    "create_animation": {
      "ui:order": [
        "camera",
        "fps",
        "duration",
        "width",
        "height"
      ]
    },
    "ui:order": [
      "workflow_details",
      "er_client_name",
      "time_range",
      "subject_group_var",
      "convert_to_trajs",
      "terrain_exaggeration",
      "trips_view_state",
      "animation_settings",
      "draw_animation",
      "video_output_path",
      "create_animation"
    ]
  },
  "additionalProperties": false
}
